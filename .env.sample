# Database (PostgreSQL) — docker-compose.yml reads these values (defaults: "ragtime" / port 5432)
RAGTIME_DB_NAME=ragtime
RAGTIME_DB_USER=ragtime
RAGTIME_DB_PASSWORD=ragtime
RAGTIME_DB_HOST=localhost
RAGTIME_DB_PORT=5432

# Scraping LLM provider (default: openai)
RAGTIME_SCRAPING_PROVIDER=
# API key for the scraping LLM provider
RAGTIME_SCRAPING_API_KEY=
# Scraping LLM model name (default: gpt-4.1-mini)
RAGTIME_SCRAPING_MODEL=

# Summarization LLM provider (default: openai)
RAGTIME_SUMMARIZATION_PROVIDER=
# API key for the summarization provider
RAGTIME_SUMMARIZATION_API_KEY=
# Summarization model name (default: gpt-4.1-mini)
RAGTIME_SUMMARIZATION_MODEL=

# Entity extraction LLM provider (default: openai)
RAGTIME_EXTRACTION_PROVIDER=
# API key for the entity extraction provider
RAGTIME_EXTRACTION_API_KEY=
# Entity extraction model name (default: gpt-4.1-mini)
RAGTIME_EXTRACTION_MODEL=

# Entity resolution LLM provider (default: openai)
RAGTIME_RESOLUTION_PROVIDER=
# API key for the entity resolution provider
RAGTIME_RESOLUTION_API_KEY=
# Entity resolution model name (default: gpt-4.1-mini)
RAGTIME_RESOLUTION_MODEL=

# Translation LLM provider — used by recovery agent to translate UI labels (default: openai)
RAGTIME_TRANSLATION_PROVIDER=
# API key for the translation provider
RAGTIME_TRANSLATION_API_KEY=
# Translation model name (default: gpt-4.1-mini)
RAGTIME_TRANSLATION_MODEL=

# Transcription backend (whisper_api, whisper_local, etc.)
RAGTIME_TRANSCRIPTION_PROVIDER=
# API key for transcription (if using API)
RAGTIME_TRANSCRIPTION_API_KEY=

# Embedding provider (default: openai)
RAGTIME_EMBEDDING_PROVIDER=
# API key for the embedding provider
RAGTIME_EMBEDDING_API_KEY=
# Embedding model name (default: text-embedding-3-small, 1536-dim, multilingual)
RAGTIME_EMBEDDING_MODEL=

# Scott — RAG chatbot
# LLM provider for Scott (default: openai)
RAGTIME_SCOTT_PROVIDER=
# API key for Scott's LLM provider
RAGTIME_SCOTT_API_KEY=
# Model name used by Scott (default: gpt-4.1-mini)
RAGTIME_SCOTT_MODEL=
# Number of chunks retrieved per search_chunks tool call (default: 5)
RAGTIME_SCOTT_TOP_K=
# Minimum cosine similarity score for retrieved chunks (default: 0.3)
RAGTIME_SCOTT_SCORE_THRESHOLD=

# Qdrant vector store — docker-compose.yml reads RAGTIME_QDRANT_PORT (default: 6333)
RAGTIME_QDRANT_HOST=
RAGTIME_QDRANT_PORT=
# Collection name (default: ragtime_chunks)
RAGTIME_QDRANT_COLLECTION=
# API key (empty for local docker; set when using Qdrant Cloud)
RAGTIME_QDRANT_API_KEY=
# Use HTTPS (default: false for local; set to true for cloud)
RAGTIME_QDRANT_HTTPS=

# Wikidata integration
# User-Agent header for Wikidata API requests (required by Wikidata policy)
RAGTIME_WIKIDATA_USER_AGENT=
# Cache backend for Wikidata: "filebased" (default, persistent) or "db" (requires createcachetable)
RAGTIME_WIKIDATA_CACHE_BACKEND=
# Cache TTL in seconds for Wikidata API responses (default: 604800 = 7 days)
RAGTIME_WIKIDATA_CACHE_TTL=
# Debounce time in ms for Wikidata search in admin UI (default: 300)
RAGTIME_WIKIDATA_DEBOUNCE_MS=
# Minimum characters before triggering Wikidata search (default: 3)
RAGTIME_WIKIDATA_MIN_CHARS=

# Telemetry (OpenTelemetry) — traces pipeline steps and LLM calls
# Comma-separated collectors to enable: console, jaeger, langfuse (default: empty = disabled)
RAGTIME_OTEL_COLLECTORS=
# Service name for traces (default: ragtime)
RAGTIME_OTEL_SERVICE_NAME=
# OTLP HTTP endpoint for Jaeger (default: http://localhost:4318)
RAGTIME_OTEL_JAEGER_ENDPOINT=

# Langfuse collector (only when "langfuse" is in RAGTIME_OTEL_COLLECTORS)
# Install with: uv sync --extra langfuse
# Langfuse secret key (from project settings)
RAGTIME_LANGFUSE_SECRET_KEY=
# Langfuse public key (from project settings)
RAGTIME_LANGFUSE_PUBLIC_KEY=
# Langfuse host URL (default: http://localhost:3000)
RAGTIME_LANGFUSE_HOST=

# Recovery layer — automatic recovery for pipeline failures
# Enable the AI agent recovery strategy (true/false, default: false)
RAGTIME_RECOVERY_AGENT_ENABLED=
# API key for the recovery agent LLM provider
RAGTIME_RECOVERY_AGENT_API_KEY=
# Pydantic AI model string (default: openai:gpt-4.1-mini). Examples: anthropic:claude-sonnet-4-20250514, openai:gpt-4.1
RAGTIME_RECOVERY_AGENT_MODEL=
# Timeout in seconds for recovery agent attempts (default: 120)
RAGTIME_RECOVERY_AGENT_TIMEOUT=

